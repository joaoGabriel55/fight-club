{
  "name": "fight-club-backend",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "backend",
  "targets": {
    "build": {
      "command": "node ace build",
      "options": {
        "cwd": "backend"
      }
    },
    "dev": {
      "command": "node ace serve --hmr",
      "options": {
        "cwd": "backend"
      }
    },
    "test": {
      "command": "node ace test",
      "options": {
        "cwd": "backend"
      }
    },
    "lint": {
      "command": "eslint .",
      "options": {
        "cwd": "backend"
      }
    },
    "typecheck": {
      "command": "tsc --noEmit",
      "options": {
        "cwd": "backend"
      }
    },
    "migrate": {
      "command": "node ace.js migration:run",
      "options": {
        "cwd": "backend"
      }
    },
    "seed": {
      "command": "node ace.js db:seed",
      "options": {
        "cwd": "backend"
      }
    }
  }
}
