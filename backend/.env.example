TZ=UTC
PORT=3333
HOST=localhost
LOG_LEVEL=info
# Generate with: node ace generate:key
APP_KEY=
APP_NAME=FightClub
NODE_ENV=development
# URL of the frontend SPA — used for strict CORS origin enforcement
VITE_APP_URL=http://localhost:3000

# PostgreSQL connection — use DATABASE_URL (Supabase/production) OR individual vars (local dev)
# DATABASE_URL takes precedence when set.
# DATABASE_URL=postgresql://postgres:PASSWORD@db.xxx.supabase.co:5432/postgres
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=fight_club
DB_PASSWORD=fight_club
DB_DATABASE=fight_club

# Valkey / Redis connection
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# Rate limiter storage driver (database | memory)
LIMITER_STORE=database

# Access token TTL (e.g. "7 days", "24 hours"). Defaults to "7 days" if unset.
TOKEN_EXPIRY=7 days

# Anthropic API key for AI features (optional)
ANTHROPIC_API_KEY=
