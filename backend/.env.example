TZ=UTC
PORT=3333
HOST=localhost
LOG_LEVEL=info
# Generate with: node ace generate:key
APP_KEY=
APP_NAME=FightClub
NODE_ENV=development
# URL of the frontend SPA — used for strict CORS origin enforcement
VITE_APP_URL=http://localhost:3000

# PostgreSQL connection
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=fight_club
DB_PASSWORD=
DB_DATABASE=fight_club

# Valkey / Redis connection
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# Rate limiter storage driver (database | memory)
LIMITER_STORE=database
